{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "scripts": {
    "dev:client": "vite dev --port 5173",
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "npx tsx script/build.ts --server-only",
    "build:vercel": "npx tsx script/build-vercel.ts",
    "vercel-build": "vite build && npx tsx script/build-vercel.ts && tsx script/vercel-db-fix.ts && drizzle-kit push --force",
    "build:legacy": "npx tsx script/build.ts",
    "start": "node dist/index.cjs",
    "start:prod": "drizzle-kit push && node dist/index.cjs",
    "render-build": "npm install --no-audit --no-fund && npm run build",
    "check": "tsc",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:push:ci": "drizzle-kit push --force",
    "db:fix:ci": "tsx script/vercel-db-fix.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-part2": "tsx script/migrate-part2.ts"
  },
