# Maximus Care — production environment template

# Server
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
JSON_BODY_LIMIT=2mb

# Dev: run `npm run dev` (API + UI on http://127.0.0.1:5000)
# Optional split dev: `npm run dev` in one terminal, `npm run dev:client` in another (UI on :5173, proxies /api → :5000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://maximus:CHANGE_ME@postgres:5432/maximus

# Auth — REQUIRED: change in production
JWT_SECRET=generate-a-long-random-secret-here
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_MS=604800000

# Cache (optional but recommended)
REDIS_URL=redis://redis:6379

# Client (if API on different origin)
# VITE_API_URL=https://your-domain.com
#
# ============================================================================
# ALL-ON-VERCEL DEPLOYMENT (frontend + backend together)
# ----------------------------------------------------------------------------
# The repo ships api/index.ts (a serverless wrapper of the Express app) and
# vercel.json so the WHOLE app runs on Vercel. To make login work, set these
# Environment Variables in the Vercel Project Settings:
#
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
#       REQUIRED. Vercel's filesystem is ephemeral, so SQLite will NOT persist.
#       Use a hosted Postgres (Neon / Vercel Postgres / Supabase). The first
#       login auto-creates the default seed users in this database.
#   JWT_SECRET=generate-a-long-random-secret-here   (REQUIRED)
#   NODE_ENV=production
#
# Leave VITE_API_URL UNSET on Vercel — the SPA and API share the same origin,
# so /api calls hit the serverless function automatically.
# Note: WebSockets and background cron jobs are disabled on Vercel (serverless).
# ============================================================================
#
# SPLIT DEPLOYMENT (Vercel SPA + separate backend on Render/Railway):
# VITE_API_URL=https://your-backend-host.onrender.com
#
# CORS — REQUIRED only for the SPLIT setup (not needed for all-on-Vercel).
# Set this on the BACKEND host to the exact frontend origin(s), comma-separated,
# with NO trailing slash. Without it the browser blocks the cross-origin login.
# CLIENT_ORIGIN=https://your-app.vercel.app,https://your-custom-domain.com

# Document storage — local filesystem used when S3_BUCKET is unset
# DOCUMENT_MAX_BYTES=10485760
# S3_BUCKET=maximus-documents
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000
# S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio123
